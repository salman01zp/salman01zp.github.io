---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: { post, nextPost: posts[index + 1] ?? null },
  }));
}

const { post, nextPost } = Astro.props;
const { Content } = await render(post);
const next = nextPost ? { href: `/blog/${nextPost.id}/`, title: nextPost.data.title } : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  next={next}
  nextLabel="Next post"
  backHref="/blog"
  backLabel="← Back to all posts"
>
  <Content />
</PostLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="All blog posts.">
  <section class="section">
    <h1>Blog</h1>
    {
      posts.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-title">
                {post.data.title}
              </a>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0 0 1.5rem;
    font-size: 1.75rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .post-title {
    font-weight: 600;
    font-size: 1.1rem;
  }

  .post-list time {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  .post-desc {
    margin: 0.4rem 0 0;
    color: var(--muted);
  }

  .muted {
    color: var(--muted);
  }
</style>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="All blog posts.">
  <section class="section">
    <h1>Blog Posts</h1>
    {
      posts.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-link">
                <span class="post-title">{post.data.title}</span>{' '}
                <span class="post-date">
                  ({post.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })})
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .post-list {
    list-style: disc;
    margin: 0;
    padding-left: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-align: left;
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }

  .post-link {
    color: var(--fg);
  }

  .post-title {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .post-date {
    color: var(--muted);
    font-weight: 400;
    text-transform: none;
  }

  .muted {
    color: var(--muted);
    text-align: center;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Quote from '../components/Quote.astro';
---

<BaseLayout title="Salman">
  <section class="section me">
    <h1>About Salman</h1>

    <p class="intro">
      Software engineer by trade, reader by habit. I build things, take notes
      on what I learn, and occasionally write them up here.
    </p>

    <h2>Personal</h2>
    <p>
      Outside of work I read widely &mdash; mostly nonfiction, systems
      thinking, and the occasional novel. I like slow mornings, long walks,
      and conversations that wander. I'm generally more interested in asking
      good questions than having quick answers.
    </p>

    <Quote source="Old carpentry proverb">Measure twice, cut once.</Quote>
    <Quote source="Attributed to Aristotle">Well begun is half done.</Quote>

    <h2>Work</h2>
    <p class="work-info">
      Software engineer, currently building backend systems and developer
      tooling. Previously worked across full-stack product teams.
    </p>
  </section>
</BaseLayout>

<style>
  .me {
    padding-top: 3.5rem;
  }

  .intro,
  p {
    text-align: left;
    color: var(--muted);
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }

  .links {
    margin-top: 1.25rem;
  }

  .dot {
    color: var(--border);
    margin: 0 0.35rem;
  }

  .me :global(.quote-block) {
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
  }

  .work-info {
    font-size: 0.9rem;
  }
</style>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { books } from '../data/books';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Salman">
  <section id="about" class="section hero">
    <h1>Hi, I'm Salman.</h1>
    <p>
      I'm a software engineer who enjoys building things, reading, and writing
      down what I learn along the way. This site is where I keep notes on
      books I like and thoughts worth sharing.
    </p>
    <p class="links">
      <a href="https://github.com/salman01zp" target="_blank" rel="noopener noreferrer">GitHub</a>
      &middot;
      <a href="mailto:salman01sp@gmail.com">Email</a>
    </p>
  </section>

  <section id="books" class="section">
    <h2>Books</h2>
    <ul class="book-list">
      {
        books.map((book) => (
          <li class="book-item">
            <span class="book-title">{book.title}</span>
            <span class="book-author">{book.author}</span>
            {book.note && <span class="book-note">{book.note}</span>}
          </li>
        ))
      }
    </ul>
  </section>

  <section id="blog" class="section">
    <h2>Blog</h2>
    {
      recentPosts.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="post-list">
          {recentPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-title">
                {post.data.title}
              </a>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
    <p><a href="/blog">All posts &rarr;</a></p>
  </section>
</BaseLayout>

<style>
  .hero h1 {
    font-size: 2rem;
    margin: 0 0 1rem;
  }

  .hero p {
    color: var(--muted);
  }

  .links {
    margin-top: 1.5rem;
  }

  .book-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .book-item {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.6rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .book-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .book-title {
    font-weight: 600;
  }

  .book-author {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .book-note {
    flex-basis: 100%;
    color: var(--muted);
    font-size: 0.9rem;
    font-style: italic;
  }

  .post-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-title {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .post-list time {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  .post-desc {
    margin: 0.4rem 0 0;
    color: var(--muted);
  }

  .muted {
    color: var(--muted);
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Salman">
  <section id="me" class="section hero">
    <p class="kicker">Hello, I'm</p>
    <h1>Salman.</h1>
    <p class="tagline">
      Software engineer by trade, reader by habit. I build things, take notes
      on what I learn, and occasionally write them up here.
    </p>
    <p class="links">
      <a href="https://github.com/salman01zp" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="dot">&bull;</span>
      <a href="mailto:salman01sp@gmail.com">Email</a>
    </p>
  </section>

  <section class="section about">
    <h2>About Salman</h2>
    <p>
      I write software for a living, and spend most of my time outside work
      reading, tinkering with small projects, and thinking about how to build
      things that last. This site is a place to keep notes on both.
    </p>

    <h3>Personal</h3>
    <p>
      Outside of work I read widely &mdash; mostly nonfiction, systems
      thinking, and the occasional novel. I like slow mornings, long walks,
      and conversations that wander. I'm generally more interested in asking
      good questions than having quick answers.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.5rem;
    padding-bottom: 3.5rem;
  }

  .kicker {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero h1 {
    font-size: clamp(2.75rem, 8vw, 4rem);
    margin: 0 0 1.25rem;
    font-style: italic;
  }

  .tagline {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 34rem;
  }

  .links {
    margin-top: 1.5rem;
  }

  .dot {
    color: var(--border);
    margin: 0 0.35rem;
  }

  .about h2 {
    font-size: 1.65rem;
    font-style: italic;
    margin: 0 0 1rem;
  }

  .about h3 {
    font-size: 1.1rem;
    font-style: italic;
    margin: 2rem 0 0.75rem;
  }

  .about p {
    color: var(--muted);
    max-width: 34rem;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Salman">
  <section id="me" class="section hero">
    <p class="kicker">Hello, I'm</p>
    <h1>Salman.</h1>
    <p class="tagline">
      Software engineer by trade, reader by habit. I build things, take notes
      on what I learn, and occasionally write them up here.
    </p>
    <p class="links">
      <a href="https://github.com/salman01zp" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="dot">&bull;</span>
      <a href="mailto:salman01sp@gmail.com">Email</a>
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.5rem;
    padding-bottom: 3.5rem;
  }

  .kicker {
    margin: 0 0 0.5rem;
    color: var(--accent-2);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero h1 {
    font-size: clamp(2.75rem, 8vw, 4rem);
    margin: 0 0 1.25rem;
    font-style: italic;
  }

  .tagline {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 34rem;
  }

  .links {
    margin-top: 1.5rem;
  }

  .dot {
    color: var(--border);
    margin: 0 0.35rem;
  }
</style>

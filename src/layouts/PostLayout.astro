---
interface NextEntry {
  href: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  next?: NextEntry | null;
  backHref?: string;
  backLabel?: string;
}

import BaseLayout from './BaseLayout.astro';

const {
  title,
  description,
  date,
  updated,
  next,
  backHref = '/blog',
  backLabel = '← Back to all posts',
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="section post">
    <header class="post-header">
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {
        updated && (
          <span class="updated">
            {' '}
            &middot; updated{' '}
            {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        )
      }
      <h1>{title}</h1>
    </header>
    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      <p class="back"><a href={backHref}>{backLabel}</a></p>
      {
        next && (
          <a href={next.href} class="next-post">
            {next.title} &rarr;
          </a>
        )
      }
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header time,
  .updated {
    display: block;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-header h1 {
    text-transform: none;
    font-weight: 600;
    font-style: italic;
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    margin: 0.75rem 0 0;
  }

  .post-footer {
    margin-top: 3rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .back {
    margin: 0;
  }

  .next-post {
    color: var(--fg);
    font-weight: 600;
    white-space: nowrap;
  }
</style>

<style is:global>
  .prose {
    font-size: 1.1rem;
  }

  .prose h2 {
    text-align: left;
    text-transform: none;
    font-weight: 600;
    font-style: italic;
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
  }

  .prose h3 {
    text-align: left;
    font-size: 1.15rem;
    margin: 1.75rem 0 0.75rem;
  }

  .prose p {
    margin: 1.1rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }

  .prose li {
    margin: 0.4rem 0;
  }

  .prose img {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .prose blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--fg);
  }

  .next-post,
  .next-post:hover {
    text-decoration: none;
  }
</style>

---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { title, description, date, updated, nextPost } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="section post">
    <header class="post-header">
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {
        updated && (
          <span class="updated">
            {' '}
            &middot; updated{' '}
            {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        )
      }
      <h1>{title}</h1>
      <span class="rule" aria-hidden="true"></span>
    </header>
    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      {
        nextPost && (
          <a href={`/blog/${nextPost.id}/`} class="next-post">
            <span class="next-label">Next post</span>
            <span class="next-title">{nextPost.data.title} &rarr;</span>
          </a>
        )
      }
      <p class="back"><a href="/blog">&larr; Back to all posts</a></p>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header time,
  .updated {
    display: block;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-header h1 {
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-style: italic;
    margin: 0.75rem 0 1.5rem;
  }

  .rule {
    display: block;
    width: 3rem;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
  }

  .post-footer {
    margin-top: 3rem;
  }

  .next-post {
    display: block;
    padding: 1.5rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--fg);
  }

  .next-post:hover {
    text-decoration: none;
    border-color: var(--accent);
  }

  .next-label {
    display: block;
    color: var(--accent-2);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .next-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
  }

  .back {
    margin-top: 1.5rem;
  }
</style>

<style is:global>
  .prose {
    font-size: 1.1rem;
  }

  .prose h2 {
    font-size: 1.5rem;
    font-style: italic;
    margin: 2.5rem 0 1rem;
  }

  .prose h3 {
    font-size: 1.15rem;
    margin: 1.75rem 0 0.75rem;
  }

  .prose p {
    margin: 1.1rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }

  .prose li {
    margin: 0.4rem 0;
  }

  .prose img {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .prose blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--fg);
  }

  .prose a {
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }

  .prose a:hover {
    text-decoration-color: var(--accent);
  }
</style>

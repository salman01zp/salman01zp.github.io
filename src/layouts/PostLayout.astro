---
interface NextEntry {
  href: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  next?: NextEntry | null;
  nextLabel?: string;
  backHref?: string;
  backLabel?: string;
}

import BaseLayout from './BaseLayout.astro';

const {
  title,
  description,
  date,
  updated,
  next,
  nextLabel = 'Next post',
  backHref = '/blog',
  backLabel = '← Back to all posts',
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="section post">
    <header class="post-header">
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {
        updated && (
          <span class="updated">
            {' '}
            &middot; updated{' '}
            {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        )
      }
      <h1>{title}</h1>
      <span class="rule" aria-hidden="true"></span>
    </header>
    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      {
        next && (
          <a href={next.href} class="next-post">
            <span class="next-label">{nextLabel}</span>
            <span class="next-title">{next.title} &rarr;</span>
          </a>
        )
      }
      <p class="back"><a href={backHref}>{backLabel}</a></p>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-header time,
  .updated {
    display: block;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-header h1 {
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-style: italic;
    margin: 0.75rem 0 0.5rem;
  }

  .rule {
    display: block;
    width: 3rem;
    height: 2px;
    background: var(--fg);
  }

  .post-footer {
    margin-top: 3rem;
  }

  .next-post {
    display: block;
    padding: 1.5rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--fg);
  }

  .next-post:hover {
    text-decoration: none;
    border-color: var(--fg);
  }

  .next-label {
    display: block;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .next-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
  }

  .back {
    margin-top: 1.5rem;
  }
</style>

<style is:global>
  .prose {
    font-size: 1.1rem;
  }

  .prose h2 {
    font-size: 1.5rem;
    font-style: italic;
    margin: 2.5rem 0 1rem;
  }

  .prose h3 {
    font-size: 1.15rem;
    margin: 1.75rem 0 0.75rem;
  }

  .prose p {
    margin: 1.1rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }

  .prose li {
    margin: 0.4rem 0;
  }

  .prose img {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .prose blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--fg);
  }

  .next-post,
  .next-post:hover {
    text-decoration: none;
  }
</style>

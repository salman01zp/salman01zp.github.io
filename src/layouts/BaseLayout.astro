---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site, book notes, and blog.' } = Astro.props;
const pageTitle = title === 'Salman' ? title : `${title} · Salman`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <nav class="site-nav">
          <a class="brand" href="/">Salman</a>
          <div class="nav-links">
            <a href="/#about">About</a>
            <a href="/#books">Books</a>
            <a href="/blog">Blog</a>
          </div>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} Salman</p>
      </footer>
    </div>
  </body>
</html>

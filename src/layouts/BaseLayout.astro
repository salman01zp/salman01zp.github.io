---
import '../styles/global.css';
import SettingsWidget from '../components/SettingsWidget.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site, book notes, and blog.' } = Astro.props;
const pageTitle = title === 'Salman' ? title : `${title} · Salman`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var theme = localStorage.getItem('theme') || 'system';
        if (theme !== 'system') {
          root.setAttribute('data-theme', theme);
        }
        if (localStorage.getItem('read-mode') === 'true') {
          root.setAttribute('data-read-mode', 'true');
        }
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <nav class="site-nav">
          <a class="brand" href="/">Salman</a>
          <div class="nav-links">
            <a href="/#about">About</a>
            <a href="/#books">Books</a>
            <a href="/blog">Blog</a>
          </div>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} Salman</p>
      </footer>
    </div>
    <SettingsWidget />
  </body>
</html>

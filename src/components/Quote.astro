---
interface Props {
  source?: string;
}

const { source } = Astro.props;
---

<figure class="quote-block">
  <blockquote>
    <slot />
  </blockquote>
  {source && <figcaption>&mdash; {source}</figcaption>}
</figure>

<style>
  .quote-block {
    margin: 2rem 0;
    padding: 0.25rem 0 0.25rem 1.5rem;
    border-left: 2px solid var(--border);
  }

  .quote-block blockquote {
    margin: 0;
    padding: 0;
    border: none;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--fg);
  }

  .quote-block blockquote :global(p) {
    margin: 0;
  }

  .quote-block figcaption {
    margin-top: 0.75rem;
    font-style: normal;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>

---
---

<div class="settings-widget" id="settings-widget">
  <button
    type="button"
    class="settings-toggle"
    id="settings-toggle"
    aria-label="Open display settings"
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"></circle>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
    </svg>
  </button>
  <div class="settings-menu" id="settings-menu" role="menu">
    <button type="button" data-theme-choice="light" role="menuitemradio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
      Light
    </button>
    <button type="button" data-theme-choice="dark" role="menuitemradio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      Dark
    </button>
    <button type="button" id="read-mode-toggle" role="menuitemradio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
      <span id="read-mode-label">Read mode</span>
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var widget = document.getElementById('settings-widget');
    var toggle = document.getElementById('settings-toggle');
    var menu = document.getElementById('settings-menu');
    var readModeBtn = document.getElementById('read-mode-toggle');
    var readModeLabel = document.getElementById('read-mode-label');
    var themeButtons = document.querySelectorAll('[data-theme-choice]');

    function syncThemeButtons() {
      var current = root.getAttribute('data-theme') || 'system';
      themeButtons.forEach(function (btn) {
        btn.setAttribute('aria-pressed', String(btn.dataset.themeChoice === current));
      });
    }

    function syncReadModeButton() {
      var active = root.getAttribute('data-read-mode') === 'true';
      readModeBtn.setAttribute('aria-pressed', String(active));
      readModeLabel.textContent = active ? 'Exit read mode' : 'Read mode';
    }

    themeButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var choice = btn.dataset.themeChoice;
        root.setAttribute('data-theme', choice);
        localStorage.setItem('theme', choice);
        syncThemeButtons();
      });
    });

    readModeBtn.addEventListener('click', function () {
      var next = root.getAttribute('data-read-mode') !== 'true';
      root.setAttribute('data-read-mode', String(next));
      localStorage.setItem('read-mode', String(next));
      syncReadModeButton();
    });

    toggle.addEventListener('click', function () {
      var open = widget.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });

    document.addEventListener('click', function (event) {
      if (!widget.contains(event.target)) {
        widget.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        widget.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    syncThemeButtons();
    syncReadModeButton();
  })();
</script>
